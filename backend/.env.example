DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=your-domain.com,api.your-domain.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://api.your-domain.com
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_COOKIES=0
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_SERVE_MEDIA=1
DJANGO_TIME_ZONE=UTC

POSTGRES_DB=pricing_estimates
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONN_HEALTH_CHECKS=1

REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_LOG_LEVEL=INFO

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
MATCH_TOP_K=3
MATCH_STRONG_THRESHOLD=0.8
MATCH_REVIEW_THRESHOLD=0.5

PORT=8000
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
